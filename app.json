{
  "expo": {
    "name": "Kriya",
    "slug": "kriya",
    "version": "1.0.1",
    "scheme": "acme",
    "icon": "./assets/icons/androidicon1.png",
    "userInterfaceStyle": "automatic",
      "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/icons/splash-icon-dark.png",
          "dark": {
            "image": "./assets/icons/splash-icon-light.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ],["react-native-android-widget", {
  // Paths to all custom fonts used in all widgets
  // "fonts": ["./assets/fonts/Inter.ttf"],
  "widgets": [
    {
      "name": "Hello", // This name will be the **name** with which we will reference our widget.
      "label": "My Hello Widget", // Label shown in the widget picker
      "minWidth": "320dp",
      "minHeight": "120dp",
      // This means the widget's default size is 5x2 cells, as specified by the targetCellWidth and targetCellHeight attributes.
      // Or 320×120dp, as specified by minWidth and minHeight for devices running Android 11 or lower.
      // If defined, targetCellWidth,targetCellHeight attributes are used instead of minWidth or minHeight.
      "targetCellWidth": 5,
      "targetCellHeight": 2,
      "description": "This is my first widget", // Description shown in the widget picker
      "previewImage": "./assets/widget-preview/hello.png", // Path to widget preview image

      // How often, in milliseconds, that this AppWidget wants to be updated.
      // The task handler will be called with widgetAction = 'UPDATE_WIDGET'.
      // Default is 0 (no automatic updates)
      // Minimum is 1800000 (30 minutes == 30 * 60 * 1000).
      "updatePeriodMillis": 1800000,
    }
  ]
}],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/icon.png",
          "color": "#0026ffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Alegreya",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Alegreya-Regular.otf",
                    "weight": 400,
                    "style": "normal"
                  }
                ]
              },
              {
                "fontFamily": "Source Serif Pro",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/SourceSerifPro-Light.otf",
                    "weight": 300,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/SourceSerifPro-Regular.otf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/SourceSerifPro-It.otf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/SourceSerifPro-Semibold.otf",
                    "weight": 600,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/SourceSerifPro-SemiboldIt.otf",
                    "weight": 600,
                    "style": "italic"
                  }
                ]
              },
              {
                "fontFamily": "Space Mono",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/spacemono_regular.ttf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/spacemono_italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  }
                ]
              },
              {
                "fontFamily": "Kalam",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Kalam-Regular.ttf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Kalam-Light.ttf",
                    "weight": 300,
                    "style": "normal"
                  }
                ]
              },
              {
                "fontFamily": "Instrument Serif",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/InstrumentSerif-Regular.ttf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/InstrumentSerif-Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/Alegreya-Regular.otf",
              "./assets/fonts/SourceSerifPro-It.otf",
              "./assets/fonts/SourceSerifPro-Light.otf",
              "./assets/fonts/SourceSerifPro-Regular.otf",
              "./assets/fonts/SourceSerifPro-Semibold.otf",
              "./assets/fonts/SourceSerifPro-SemiboldIt.otf",
              "./assets/fonts/spacemono_italic.ttf",
              "./assets/fonts/spacemono_regular.ttf",
              "./assets/fonts/Kalam-Regular.ttf",
              "./assets/fonts/Kalam-Light.ttf",
              "./assets/fonts/InstrumentSerif-Italic.ttf",
              "./assets/fonts/InstrumentSerif-Regular.ttf"
            ]
          }
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Kriya to access your photos.",
          "savePhotosPermission": "Allow Kriya to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-router",
      "expo-sqlite"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.surya7314.kriya",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize"
    },
    "ios": {
      "bundleIdentifier": "com.surya7314.kriya",
      "icon": "./assets/icons/iosicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3d4eb143-ca08-4c6a-8561-143653d4c80f"
      }
    },
    "owner": "surya7314"
  }
}
